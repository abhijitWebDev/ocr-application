{
  "expo": {
    "name": "ocr-sample",
    "slug": "ocr-sample",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ocrsample",
    "userInterfaceStyle": "automatic",
    "ios": {
      "bundleIdentifier": "com.abhijitdev.ocrsample",
      "buildNumber": "1",
      "icon": "./assets/images/icon.png",
      "supportsTablet": false,
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan invoices and receipts",
        "NSPhotoLibraryUsageDescription": "Used to select invoice images from your photo library",
        "NSPhotoLibraryAddUsageDescription": "Used to save scanned invoice images"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.abhijitdev.ocrsample",
      "versionCode": 1,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Used to scan invoices and receipts"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Used to select invoice images from your photo library"
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "7f63c5d9-340d-461e-8c84-2fe17363808b"
      }
    }
  }
}
